{
  "name": "bbellini-io",
  "compatibility_date": "2026-06-28",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },

  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "bbellini.io",
      "custom_domain": true
    }
  ]
}
