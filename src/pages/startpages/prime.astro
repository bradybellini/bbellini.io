---
import RootLayout from "../../layouts/RootLayout.astro";
import PictureModule from "../../components/PictureModule.astro";
import LinkGroup from "../../components/LinkGroup.astro";
import TerminalWindow from "../../components/TerminalWindow.astro";
import SearchForm from "../../components/SearchForm.astro";
import { primeLinkData as linkData } from "../../data/startpageLinks";
---

<RootLayout title="Prime - Personal Start Page">
  <SearchForm />
  
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <!-- First column -->
    <div class="space-y-4">
      <TerminalWindow title="MEDIA" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.media} />
      </TerminalWindow>
      <TerminalWindow title="AI" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.ai} />
      </TerminalWindow>
      <TerminalWindow title="OTHER" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.other} />
      </TerminalWindow>
    </div>
    
    <!-- Second column -->
    <div class="space-y-4">
      <TerminalWindow title="TECH" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.tech} />
      </TerminalWindow>
      <TerminalWindow title="PERSONAL" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.personal} />
      </TerminalWindow>
            <PictureModule />

    </div>
    
    <!-- Third column -->
    <div class="space-y-4">
      <TerminalWindow title="FINANCE" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.finance} />
      </TerminalWindow>
      <TerminalWindow title="NEWS" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.news} />
      </TerminalWindow>
      <TerminalWindow title="ECOMMERCE" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.ecommerce} />
      </TerminalWindow>
      <TerminalWindow title="SOCIAL" titleClass="text-[8px] uppercase" contentClass="text-[8px]" windowClass="w-full">
        <LinkGroup links={linkData.social} />
      </TerminalWindow>
    </div>
  </div>
</RootLayout>
