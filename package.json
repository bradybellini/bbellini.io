{
  "name": "bbellini-io",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation astro dev",
    "start": "bun run dev",
    "build": "NODE_OPTIONS=--no-deprecation astro check && NODE_OPTIONS=--no-deprecation astro build",
    "preview": "NODE_OPTIONS=--no-deprecation wrangler dev",
    "deploy": "NODE_OPTIONS=--no-deprecation wrangler deploy",
    "astro": "NODE_OPTIONS=--no-deprecation astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "7.0.3",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260628.1"
  }
}
